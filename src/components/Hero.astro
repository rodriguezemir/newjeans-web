---
const online_players = fetch("https://api.mcsrvstat.us/2/newjeans.lat")
  .then((res) => res.json())
  .then((data) => data.players.online)
  .catch(() => "N/A");
---

<img
  src="/hero_bg.gif"
  alt="Hero Background"
  class="absolute inset-0 w-full h-full object-cover opacity-50 -z-2"
/>
<section
  class="hero flex flex-col items-center h-screen text-center bg-cover bg-center"
>
  <h1 class="font-black mt-20 text-7xl">
    Servidor De Minecraft <br />
    de <span
      class="bg-linear-to-r from-purple-700 to-yellow-500 bg-clip-text text-transparent"
      >Sword PvP</span
    >
  </h1>
  <button
    class="mt-10 px-6 py-3 bg-purple-700 text-white font-bold rounded-lg border-2 border-purple-900 transition-all hover:bg-purple-600 focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2"
  >
    Join Server
  </button>
  <div
    class="bg-purple-700/30 border-2 rounded-2xl p-4 border-purple-700 flex flex-row items-center justify-center space-x-4 mt-10"
  >
    <h3 class="text-xl font-semibold uppercase text-gray-300">
      Jugadores Conectados:
    </h3>
    <p class="text-xl font-semibold font-mono">{online_players}</p>
  </div>
</section>
